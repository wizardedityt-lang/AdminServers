        SKnob.Size = UDim2.new(0, 20, 0, 20); SKnob.Position = UDim2.new(1, -10, 0.5, -10); SKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); SKnob.Active = true; SKnob.ZIndex = 18
