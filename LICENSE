local function UpdateUI(toggleBtn, state)
    if state then toggleBtn.Text = "ON"; toggleBtn.TextColor3 = Color3.fromRGB(80, 255, 80)
    else toggleBtn.Text = "OFF"; toggleBtn.TextColor3 = Color3.fromRGB(255, 80, 80) end
end

-- SÜRÜKLEME VE ARAYÜZ YARDIMCILARI
local function MakeDraggable(TopBar, FrameToMove)
    local dragging, dragInput, mousePos, framePos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; mousePos = input.Position; framePos = FrameToMove.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            FrameToMove.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
        end
    end)
end
MakeDraggable(Title, MainFrame)
MakeDraggable(PanelTitle, PlayerPanelFrame)

-- KAYITLI SLIDER SİSTEMİ
local function SetupSlider(SliderObj, configKey, maxValue, callback)
    local sliding = false
    local startVal = NebulaConfig.Sliders[configKey] or 50
    SliderObj.Input.Text = tostring(startVal)
    SliderObj.Fill.Size = UDim2.new(startVal / maxValue, 0, 1, 0)
    callback(startVal)

    local function updateValue(val)
        val = math.clamp(math.floor(val), 1, maxValue)
        SliderObj.Fill.Size = UDim2.new(val / maxValue, 0, 1, 0)
        SliderObj.Input.Text = tostring(val)
        
        NebulaConfig.Sliders[configKey] = val
        SaveConfig()
        callback(val)
    end

    local function startSliding(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true end end
    SliderObj.Knob.InputBegan:Connect(startSliding); SliderObj.Bar.InputBegan:Connect(startSliding)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end end)
    
    RunService.RenderStepped:Connect(function()
        if sliding then
            local mouseX = UserInputService:GetMouseLocation().X
            local barX = SliderObj.Bar.AbsolutePosition.X
            local percentage = math.clamp((mouseX - barX) / SliderObj.Bar.AbsoluteSize.X, 0, 1)
            updateValue(percentage * maxValue)
        end
    end)
    
    SliderObj.Input.FocusLost:Connect(function()
        local num = tonumber(SliderObj.Input.Text)
        if num then updateValue(num) else updateValue(NebulaConfig.Sliders[configKey]) end
    end)
end

-- // GÜNCELLENMİŞ KAYITLI KEYBIND SİSTEMİ (nil Hatası Düzeltildi) //
local function SetupKeybind(KeyBtn, configKey, actionFunc)
    local currentKeyName = NebulaConfig.Keybinds[configKey]
    local currentKey = nil
    
    if currentKeyName and currentKeyName ~= "None" then 
        pcall(function() currentKey = Enum.KeyCode[currentKeyName] end) 
    end
    
    local isBinding = false
    if currentKey then KeyBtn.Text = "[ "..currentKey.Name.." ]" else KeyBtn.Text = "[ + ]" end

    KeyBtn.MouseButton1Click:Connect(function()
        if isBinding then
            isBinding = false; currentKey = nil; NebulaConfig.Keybinds[configKey] = "None"
            SaveConfig(); KeyBtn.Text = "[ + ]"; KeyBtn.TextColor3 = Color3.fromRGB(165, 94, 234)
        else
            isBinding = true; KeyBtn.Text = "..."; KeyBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
        end
    end)

    local conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if isBinding then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode == Enum.KeyCode.Backspace or input.KeyCode == Enum.KeyCode.Escape then
                    currentKey = nil; NebulaConfig.Keybinds[configKey] = "None"; KeyBtn.Text = "[ + ]"
                else
                    currentKey = input.KeyCode; NebulaConfig.Keybinds[configKey] = currentKey.Name; KeyBtn.Text = "[ "..currentKey.Name.." ]"
                end
                KeyBtn.TextColor3 = Color3.fromRGB(165, 94, 234)
                SaveConfig(); isBinding = false
            end
        elseif currentKey and input.KeyCode == currentKey and not gameProcessed then
            actionFunc() 
        end
    end)
    table.insert(eventConnections, conn)
end


