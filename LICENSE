local LocalPlayer = Players.LocalPlayer

-- // Ayar Kaydetme Sistemi (Config System) //
local configName = "NebulaHub_Config.json"
local NebulaConfig = {
    Sliders = {
        FlySpeed = 50,
        WalkSpeed = 50,
        SpinSpeed = 1
    },
    Keybinds = {
        Fly = "F", WalkSpeed = "Z", Spin = "C",
        Jump = "None", Noclip = "None", GlobalESP = "E",
        AutoTP = "None", MM2ESP = "None", AutoGrab = "None", AntiFling = "None"
    }
}

-- Dosyadan Ayarları Yükle
local function LoadConfig()
    pcall(function()
        if isfile and isfile(configName) and readfile then
            local data = HttpService:JSONDecode(readfile(configName))
            if data then
                if data.Sliders then for k, v in pairs(data.Sliders) do NebulaConfig.Sliders[k] = v end end
                if data.Keybinds then for k, v in pairs(data.Keybinds) do NebulaConfig.Keybinds[k] = v end end
            end
        end
    end)
end

-- Dosyaya Ayarları Kaydet
local function SaveConfig()
    pcall(function()
        if writefile then writefile(configName, HttpService:JSONEncode(NebulaConfig)) end
    end)
end

LoadConfig()

