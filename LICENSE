local AutoTPMod, AutoTPToggle, _, AutoTPKey = CreateModule("⏱️ Otomatik TP (2 Saniye)", false, LocScrollFrame)

local function UpdateAutoTP()
    if isAutoTPEnabled then
        autoTPLoopConn = RunService.Stepped:Connect(function()
            if tick() - lastTPTime >= 2.0 then -- 2 Saniye aralıklarla ışınlar
                lastTPTime = tick()
                if activeTplocation and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = activeTplocation
                    LocalPlayer.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
                end
            end
        end)
    else
        if autoTPLoopConn then autoTPLoopConn:Disconnect(); autoTPLoopConn = nil end
    end
end

local function ToggleAutoTP() 
    if not activeTplocation then
        AutoTPToggle.Text = "SEÇİM YOK"
        task.delay(1, function() UpdateUI(AutoTPToggle, isAutoTPEnabled) end)
        return
    end
    isAutoTPEnabled = not isAutoTPEnabled; 
    UpdateUI(AutoTPToggle, isAutoTPEnabled); 
    UpdateAutoTP() 
end
AutoTPToggle.MouseButton1Click:Connect(ToggleAutoTP); SetupKeybind(AutoTPKey, "AutoTP", ToggleAutoTP)


-- // İZLEME VE OYUNCU LİSTESİ SİSTEMİ //
local function UpdateSpectate()
    if spectateConn then spectateConn:Disconnect(); spectateConn = nil end
    if spectatedPlayer then
        local function ApplyCamera()
            if spectatedPlayer and spectatedPlayer.Character and spectatedPlayer.Character:FindFirstChild("Humanoid") then
                workspace.CurrentCamera.CameraSubject = spectatedPlayer.Character.Humanoid
            end
        end
        ApplyCamera()
        spectateConn = spectatedPlayer.CharacterAdded:Connect(function(char) task.wait(0.5); ApplyCamera() end)
    else
        local myChar = LocalPlayer.Character
        if myChar and myChar:FindFirstChild("Humanoid") then workspace.CurrentCamera.CameraSubject = myChar.Humanoid end
    end
end

local function UpdateAttach()
    if attachLoop then attachLoop:Disconnect(); attachLoop = nil end
    if attachedPlayer then
        attachLoop = RunService.Heartbeat:Connect(function()
            local lChar = LocalPlayer.Character
            local tChar = attachedPlayer.Character
            if lChar and tChar then
                local lHRP = lChar:FindFirstChild("HumanoidRootPart")
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                if lHRP and tHRP then
                    lHRP.CFrame = CFrame.new(tHRP.Position) * (lHRP.CFrame - lHRP.Position)
                end
            end
        end)
    end
end

local function RefreshPlayerList()
    for _, child in ipairs(PlayerScrollFrame:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local PFrame = Instance.new("Frame", PlayerScrollFrame)
        PFrame.Size = UDim2.new(1, -20, 0, 50); PFrame.BackgroundColor3 = Color3.fromRGB(30, 25, 45); PFrame.ZIndex = 12
        Instance.new("UICorner", PFrame).CornerRadius = UDim.new(0, 8)

        local Avatar = Instance.new("ImageLabel", PFrame)
        Avatar.Size = UDim2.new(0, 40, 0, 40); Avatar.Position = UDim2.new(0, 5, 0, 5); Avatar.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Avatar.ZIndex = 13
        Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1, 0)
        coroutine.wrap(function()
            local thumb = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            Avatar.Image = thumb
        end)()

        local NameLbl = Instance.new("TextLabel", PFrame)
        NameLbl.Size = UDim2.new(0, 160, 1, 0); NameLbl.Position = UDim2.new(0, 55, 0, 0); NameLbl.BackgroundTransparency = 1; NameLbl.ZIndex = 13
        NameLbl.Text = player.DisplayName .. "\n(@" .. player.Name .. ")"; NameLbl.TextColor3 = Color3.fromRGB(230, 230, 230); NameLbl.Font = Enum.Font.GothamSemibold; NameLbl.TextSize = 11; NameLbl.TextXAlignment = Enum.TextXAlignment.Left

        local TPBtn = Instance.new("TextButton", PFrame)
        TPBtn.Size = UDim2.new(0, 35, 0, 30); TPBtn.Position = UDim2.new(1, -40, 0, 10); TPBtn.BackgroundColor3 = Color3.fromRGB(165, 94, 234); TPBtn.ZIndex = 14
        TPBtn.Text = "TP"; TPBtn.TextColor3 = Color3.fromRGB(255, 255, 255); TPBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", TPBtn).CornerRadius = UDim.new(0, 6)
        TPBtn.MouseButton1Click:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
            end
        end)

        local AttachBtn = Instance.new("TextButton", PFrame)
        AttachBtn.Size = UDim2.new(0, 35, 0, 30); AttachBtn.Position = UDim2.new(1, -80, 0, 10); AttachBtn.ZIndex = 14
        AttachBtn.BackgroundColor3 = (attachedPlayer == player) and Color3.fromRGB(255, 60, 100) or Color3.fromRGB(60, 50, 80)
        AttachBtn.Text = "🧲"; AttachBtn.TextColor3 = Color3.fromRGB(255, 255, 255); AttachBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", AttachBtn).CornerRadius = UDim.new(0, 6)
        AttachBtn.MouseButton1Click:Connect(function()
            if attachedPlayer == player then attachedPlayer = nil else attachedPlayer = player end
            UpdateAttach()
            RefreshPlayerList()
        end)

        local ESPBtn = Instance.new("TextButton", PFrame)
        ESPBtn.Size = UDim2.new(0, 45, 0, 30); ESPBtn.Position = UDim2.new(1, -130, 0, 10); ESPBtn.ZIndex = 14
        ESPBtn.BackgroundColor3 = activeESPs[player] and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(60, 50, 80)
        ESPBtn.Text = "ESP"; ESPBtn.TextColor3 = Color3.fromRGB(255, 255, 255); ESPBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", ESPBtn).CornerRadius = UDim.new(0, 6)
        ESPBtn.MouseButton1Click:Connect(function()
            activeESPs[player] = not activeESPs[player]
            if activeESPs[player] then ESPBtn.BackgroundColor3 = Color3.fromRGB(80, 255, 80); ApplyESP(player)
            else ESPBtn.BackgroundColor3 = Color3.fromRGB(60, 50, 80); if not isGlobalESPEnabled then RemoveESP(player) end end
        end)

        local SpecBtn = Instance.new("TextButton", PFrame)
        SpecBtn.Size = UDim2.new(0, 35, 0, 30); SpecBtn.Position = UDim2.new(1, -170, 0, 10); SpecBtn.ZIndex = 14
        SpecBtn.BackgroundColor3 = (spectatedPlayer == player) and Color3.fromRGB(255, 165, 0) or Color3.fromRGB(60, 50, 80)
        SpecBtn.Text = "👁️"; SpecBtn.TextColor3 = Color3.fromRGB(255, 255, 255); SpecBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", SpecBtn).CornerRadius = UDim.new(0, 6)
        SpecBtn.MouseButton1Click:Connect(function()
            if spectatedPlayer == player then spectatedPlayer = nil else spectatedPlayer = player end
            UpdateSpectate()
            RefreshPlayerList()
        end)
    end
end

Players.PlayerAdded:Connect(function(player) RefreshPlayerList(); player.CharacterAdded:Connect(function() task.wait(1); if activeESPs[player] or isGlobalESPEnabled then ApplyESP(player) end end) end)
Players.PlayerRemoving:Connect(function(player) 
    activeESPs[player] = nil
    if spectatedPlayer == player then spectatedPlayer = nil; UpdateSpectate() end
    if attachedPlayer == player then attachedPlayer = nil; UpdateAttach() end
    RefreshPlayerList() 
end)
for _, p in ipairs(Players:GetPlayers()) do p.CharacterAdded:Connect(function() task.wait(1); if activeESPs[p] or isGlobalESPEnabled then ApplyESP(p) end end) end
RefreshPlayerList()

-- ==========================================
-- // MM2 ÖZEL SEKME FONKSİYONLARI (KUSURSUZ GÜNCELLEME) //
-- ==========================================
local MM2ESPMod, MM2ESPToggle, _, MM2ESPKey = CreateModule("🔪 MM2 Rol ESP (Şerif/Katil)", false, MM2ScrollFrame)
local AutoGrabMod, AutoGrabToggle, _, AutoGrabKey = CreateModule("🔫 Auto Grab Gun (Silah Kap)", false, MM2ScrollFrame)
local AntiFlingMod, AntiFlingToggle, _, AntiFlingKey = CreateModule("🛡️ Anti Fling (Çarpışma Kapat)", false, MM2ScrollFrame)

local mm2ActiveESPs = {}

local function ClearAllMM2ESP()
    for _, hl in ipairs(mm2ActiveESPs) do
        if hl then pcall(function() hl:Destroy() end) end
    end
    mm2ActiveESPs = {}
    
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Highlight") and v.Name == "MM2RoleESP" then
            pcall(function() v:Destroy() end)
        end
    end
end

local function UpdateMM2ESP()
    if isMM2ESPEnabled then
        mm2ESPLoop = RunService.Heartbeat:Connect(function()
            for i = #mm2ActiveESPs, 1, -1 do
                local hl = mm2ActiveESPs[i]
                if not hl or not hl.Parent or not hl.Parent.Parent then
                    table.remove(mm2ActiveESPs, i)
                else
                    local plr = Players:GetPlayerFromCharacter(hl.Parent)
                    local hum = hl.Parent:FindFirstChildOfClass("Humanoid")
                    if not plr or not hum or hum.Health <= 0 then
                        pcall(function() hl:Destroy() end)
                        table.remove(mm2ActiveESPs, i)
                    end
                end
            end

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local char = player.Character
                    if char then
                        local humanoid = char:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            local role = "Masum"
                            local color = Color3.fromRGB(0, 255, 0)

                            local function checkTools(parent)
                                if not parent then return end
                                pcall(function()
                                    for _, item in ipairs(parent:GetChildren()) do
                                        if item:IsA("Tool") then
                                            local itemName = string.lower(item.Name)
                                            if itemName:find("radio") or itemName:find("boombox") or itemName:find("teddy") or itemName:find("emote") or itemName:find("toy") then
                                                continue
                                            end
                                            
                                            local handle = item:FindFirstChild("Handle")
                                            if handle then
                                                local isGun, isKnife = false, false
                                                for _, child in ipairs(handle:GetChildren()) do
                                                    if child:IsA("Sound") then
                                                        local sName = string.lower(child.Name)
                                                        if sName:find("shoot") or sName:find("fire") or sName:find("reload") or sName:find("gun") then
                                                            isGun = true
                                                        elseif sName:find("slash") or sName:find("stab") or sName:find("throw") or sName:find("knife") then
                                                            isKnife = true
                                                        end
                                                    end
                                                end
                                                if isGun then role = "Şerif"; color = Color3.fromRGB(0, 0, 255); return
                                                elseif isKnife then role = "Katil"; color = Color3.fromRGB(255, 0, 0); return end
                                            end
                                            
                                            if itemName:find("gun") or itemName:find("revolver") or itemName:find("blaster") or itemName:find("laser") or itemName:find("luger") or itemName:find("vintage") then
                                                role = "Şerif"; color = Color3.fromRGB(0, 0, 255); return
                                            elseif itemName:find("knife") or itemName:find("blade") or itemName:find("scythe") or itemName:find("saw") or itemName:find("slasher") or itemName:find("karambit") or itemName:find("fang") or itemName:find("edge") or itemName:find("battleaxe") or itemName:find("axe") or itemName:find("dagger") or itemName:find("sword") or itemName:find("shatter") or itemName:find("pitchfork") or itemName:find("sickle") or itemName:find("machete") then
                                                role = "Katil"; color = Color3.fromRGB(255, 0, 0); return
                                            end
                                        end
                                    end
                                end)
                            end
                            
                            checkTools(player:FindFirstChild("Backpack"))
                            if role == "Masum" then checkTools(char) end

                            local hl = char:FindFirstChild("MM2RoleESP")
                            if not hl then
                                hl = Instance.new("Highlight")
                                hl.Name = "MM2RoleESP"
                                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                                hl.Parent = char
                                
                                local bill = Instance.new("BillboardGui", hl)
                                bill.Name = "RoleText"
                                bill.Size = UDim2.new(0, 100, 0, 30)
                                bill.StudsOffset = Vector3.new(0, 1.5, 0)
                                bill.AlwaysOnTop = true
                                
                                local txt = Instance.new("TextLabel", bill)
                                txt.Size = UDim2.new(1, 0, 1, 0)
                                txt.BackgroundTransparency = 1
                                txt.Font = Enum.Font.GothamBlack
                                txt.TextSize = 14
                                txt.TextStrokeTransparency = 0
                                
                                table.insert(mm2ActiveESPs, hl)
                            end
                            
                            local targetPart = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                            if targetPart and hl:FindFirstChild("RoleText") then hl.RoleText.Adornee = targetPart end
                            
                            hl.FillColor = color; hl.OutlineColor = color; hl.FillTransparency = 0.6
                            local textLabel = hl:FindFirstChild("RoleText") and hl.RoleText:FindFirstChildOfClass("TextLabel")
                            if textLabel then textLabel.Text = role; textLabel.TextColor3 = color end
                        end
                    end
                end
            end
        end)
    else
        if mm2ESPLoop then mm2ESPLoop:Disconnect(); mm2ESPLoop = nil end
        ClearAllMM2ESP()
    end
end

local function ToggleMM2ESP() 
    isMM2ESPEnabled = not isMM2ESPEnabled
    UpdateUI(MM2ESPToggle, isMM2ESPEnabled)
    if not isMM2ESPEnabled then ClearAllMM2ESP() end
    UpdateMM2ESP() 
end
MM2ESPToggle.MouseButton1Click:Connect(ToggleMM2ESP); SetupKeybind(MM2ESPKey, "MM2ESP", ToggleMM2ESP)


local function FindGunDrop()
    local directDrop = workspace:FindFirstChild("GunDrop") or workspace:FindFirstChild("RevolverDrop")
    if directDrop then return directDrop end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "GunDrop" or obj.Name == "RevolverDrop" then
            if (obj:IsA("BasePart") or obj:IsA("Model")) and obj.Parent and not obj.Parent:FindFirstChild("Humanoid") then
                return obj
            end
        end
    end
    return nil
end

local function CheckIfHasGun(parent)
    if not parent then return false end
    for _, item in ipairs(parent:GetChildren()) do
        if item:IsA("Tool") then
            local lower = string.lower(item.Name)
            if lower:find("gun") or lower:find("revolver") or lower:find("blaster") or lower:find("laser") or lower:find("luger") or lower:find("vintage") then return true end
        end
    end
    return false
end

-- DİREKT SİLAHI ÇEKME & KAMERA KİLİTLİ "IŞIK HIZI (1 FRAME)" TP (EKRAN TİTREMEZ)
local function UpdateAutoGrab()
    if isAutoGrabEnabled then
        autoGrabLoop = RunService.Heartbeat:Connect(function()
            if not isAutoGrabEnabled or grabbingGun then return end
            
            local char = LocalPlayer.Character
            if not char then return end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            if CheckIfHasGun(LocalPlayer.Backpack) or CheckIfHasGun(char) then return end
            
            local gunDrop = FindGunDrop()
            
            if gunDrop then
                grabbingGun = true
                
                task.spawn(function()
                    local oldCFrame = hrp.CFrame
                    local cam = workspace.CurrentCamera
                    local oldCamCFrame = cam.CFrame
                    
                    local dropCFrame
                    if gunDrop:IsA("Model") then
                        dropCFrame = gunDrop:GetPivot()
                    elseif gunDrop:IsA("BasePart") then
                        dropCFrame = gunDrop.CFrame
                    end
                    
                    if dropCFrame then
                        -- ADIM 1: SİLAHI LOKAL OLARAK (Senin ekranında) YANINA ÇEK
                        pcall(function()
                            if gunDrop:IsA("Model") then
                                gunDrop:PivotTo(oldCFrame)
                            elseif gunDrop:IsA("BasePart") then
                                gunDrop.CFrame = oldCFrame
                            end
                        end)

                        -- ADIM 2: EKRANIN ASLA TİTREMEMESİ İÇİN KAMERAYI GEÇİCİ OLARAK DONDUR
                        cam.CameraType = Enum.CameraType.Scriptable
                        cam.CFrame = oldCamCFrame

                        -- ADIM 3: IŞIK HIZINDA (Anında) SİLAHA GİT
                        hrp.CFrame = dropCFrame
                        hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                        
                        -- Varsa FireTouchinterest ile silaha doğrudan "dokundum" sinyali gönder
                        if firetouchinterest then
                            if gunDrop:IsA("BasePart") then
                                pcall(firetouchinterest, hrp, gunDrop, 0)
                                pcall(firetouchinterest, hrp, gunDrop, 1)
                            end
                            for _, part in ipairs(gunDrop:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    pcall(firetouchinterest, hrp, part, 0)
                                    pcall(firetouchinterest, hrp, part, 1)
                                end
                            end
                        end
                        
                        -- Sunucunun seni orda görüp silahı sana vermesi için YALNIZCA 1 FRAME (Saniyenin 60'ta 1'i) bekle
                        RunService.Heartbeat:Wait()
                        
                        -- ADIM 4: IŞIK HIZINDA GERİ DÖN VE KAMERAYI ÇÖZ
                        hrp.CFrame = oldCFrame
                        hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                        
                        cam.CameraType = Enum.CameraType.Custom
                    end
                    
                    task.wait(0.2)
                    grabbingGun = false
                end)
            end
        end)
    else
        if autoGrabLoop then autoGrabLoop:Disconnect(); autoGrabLoop = nil end
        grabbingGun = false
    end
end
local function ToggleAutoGrab() isAutoGrabEnabled = not isAutoGrabEnabled; UpdateUI(AutoGrabToggle, isAutoGrabEnabled); UpdateAutoGrab() end
AutoGrabToggle.MouseButton1Click:Connect(ToggleAutoGrab); SetupKeybind(AutoGrabKey, "AutoGrab", ToggleAutoGrab)

local function UpdateAntiFling()
    if isAntiFlingEnabled then
        antiFlingLoop = RunService.Stepped:Connect(function()
            pcall(function()
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        for _, part in ipairs(player.Character:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                                if part.AssemblyLinearVelocity.Magnitude > 200 or part.AssemblyAngularVelocity.Magnitude > 200 then
                                    part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                    part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                                end
                            end
                        end
                    end
                end
            end)
        end)
    else
        if antiFlingLoop then antiFlingLoop:Disconnect(); antiFlingLoop = nil end
    end
end
local function ToggleAntiFling() isAntiFlingEnabled = not isAntiFlingEnabled; UpdateUI(AntiFlingToggle, isAntiFlingEnabled); UpdateAntiFling() end
AntiFlingToggle.MouseButton1Click:Connect(ToggleAntiFling); SetupKeybind(AntiFlingKey, "AntiFling", ToggleAntiFling)

-- // KAPATMA BÖLÜMÜ //
CloseBtn.MouseButton1Click:Connect(function()
    isFlying = false; UpdateFly()
    isSpeedEnabled = false; UpdateSpeed()
    isSpinning = false; UpdateSpin() 
    isNoclipEnabled = false; UpdateNoclip()
    isGlobalESPEnabled = false; UpdateGlobalESP()
    isMM2ESPEnabled = false; UpdateMM2ESP()
    isAutoGrabEnabled = false; UpdateAutoGrab()
    isAutoTPEnabled = false; UpdateAutoTP()
    isAntiFlingEnabled = false; UpdateAntiFling()
    
    spectatedPlayer = nil; UpdateSpectate()
    attachedPlayer = nil; UpdateAttach()
    activeTplocation = nil
    ClearAllMM2ESP()
    
    for _, p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
    for _, conn in ipairs(eventConnections) do if conn then conn:Disconnect() end end
    ScreenGui:Destroy()
end)
