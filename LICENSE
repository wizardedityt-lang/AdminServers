    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(0, 180, 0, 30); Label.Position = UDim2.new(0, 15, 0, 10); Label.BackgroundTransparency = 1
    Label.Text = name; Label.TextColor3 = Color3.fromRGB(230, 230, 230); Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 14; Label.TextXAlignment = Enum.TextXAlignment.Left; Label.ZIndex = 16

    local KeybindBtn = Instance.new("TextButton", Frame)
    KeybindBtn.Size = UDim2.new(0, 60, 0, 30); KeybindBtn.Position = UDim2.new(1, -135, 0, 10)
    KeybindBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); KeybindBtn.Text = "[ + ]"
    KeybindBtn.TextColor3 = Color3.fromRGB(165, 94, 234); KeybindBtn.Font = Enum.Font.GothamBold; KeybindBtn.TextSize = 13; KeybindBtn.ZIndex = 17
