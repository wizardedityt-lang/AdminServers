local function CreateScrollFrame()
    local sf = Instance.new("ScrollingFrame", MainFrame)
    sf.Size = UDim2.new(1, -10, 1, -95)
    sf.Position = UDim2.new(0, 5, 0, 85)
    sf.BackgroundTransparency = 1
    sf.ScrollBarThickness = 6
    sf.ScrollBarImageColor3 = Color3.fromRGB(165, 94, 234)
    sf.CanvasSize = UDim2.new(0, 0, 0, 1000)
    sf.ZIndex = 11
    local layout = Instance.new("UIListLayout", sf)
    layout.Padding = UDim.new(0, 10)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        sf.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)
    return sf
end

local MainScrollFrame = CreateScrollFrame()
local LocScrollFrame = CreateScrollFrame()
local MM2ScrollFrame = CreateScrollFrame()
LocScrollFrame.Visible = false
MM2ScrollFrame.Visible = false

local function SwitchTab(activeBtn, activeFrame)
    local frames = {MainScrollFrame, LocScrollFrame, MM2ScrollFrame}
    local btns = {MainTabBtn, LocTabBtn, MM2TabBtn}
    
    for _, f in ipairs(frames) do f.Visible = (f == activeFrame) end
    for _, b in ipairs(btns) do
        if b == activeBtn then
            b.BackgroundColor3 = Color3.fromRGB(165, 94, 234); b.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            b.BackgroundColor3 = Color3.fromRGB(40, 30, 60); b.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
    end
end

MainTabBtn.MouseButton1Click:Connect(function() SwitchTab(MainTabBtn, MainScrollFrame) end)
LocTabBtn.MouseButton1Click:Connect(function() SwitchTab(LocTabBtn, LocScrollFrame) end)
MM2TabBtn.MouseButton1Click:Connect(function() SwitchTab(MM2TabBtn, MM2ScrollFrame) end)

