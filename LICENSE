-- STANDART ESP FONKSİYONLARI
local function ApplyESP(player)
    if player.Character and not player.Character:FindFirstChild("PremiumESP") then
        local hl = Instance.new("Highlight")
        hl.Name = "PremiumESP"; hl.FillColor = Color3.fromRGB(165, 94, 234); hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.6; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = player.Character
    end
end

local function RemoveESP(player)
    if player.Character and player.Character:FindFirstChild("PremiumESP") then player.Character.PremiumESP:Destroy() end
end

local function UpdateGlobalESP()
    if isGlobalESPEnabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then ApplyESP(player) end
        end
    else
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and not activeESPs[player] then RemoveESP(player) end
        end
    end
end
local function ToggleGlobalESP() isGlobalESPEnabled = not isGlobalESPEnabled; UpdateUI(GlobalESPToggle, isGlobalESPEnabled); UpdateGlobalESP() end
GlobalESPToggle.MouseButton1Click:Connect(ToggleGlobalESP); SetupKeybind(GlobalESPKey, "GlobalESP", ToggleGlobalESP)

-- Orijinal Fly Kodu
local function UpdateFly()
    local char = LocalPlayer.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local HRP = char.HumanoidRootPart; local Humanoid = char:FindFirstChildOfClass("Humanoid")
    if isFlying then
        Humanoid.PlatformStand = true
        if HRP:FindFirstChild("FlyAttachment") then HRP.FlyAttachment:Destroy() end
        if HRP:FindFirstChild("FlyLinear") then HRP.FlyLinear:Destroy() end
        if HRP:FindFirstChild("FlyAlign") then HRP.FlyAlign:Destroy() end
        local attachment = Instance.new("Attachment", HRP); attachment.Name = "FlyAttachment"
        local lv = Instance.new("LinearVelocity", HRP); lv.Name = "FlyLinear"; lv.Attachment0 = attachment; lv.MaxForce = math.huge; lv.VectorVelocity = Vector3.new(0, 0, 0); lv.RelativeTo = Enum.ActuatorRelativeTo.World
        local align = Instance.new("AlignOrientation", HRP); align.Name = "FlyAlign"; align.Attachment0 = attachment; align.Mode = Enum.OrientationAlignmentMode.OneAttachment; align.MaxTorque = math.huge; align.CFrame = workspace.CurrentCamera.CFrame
        flyLoop = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera; align.CFrame = cam.CFrame
            local moveDir = Vector3.new(0,0,0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end; lv.VectorVelocity = moveDir * NebulaConfig.Sliders.FlySpeed
        end)
    else
        Humanoid.PlatformStand = false; Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        if HRP:FindFirstChild("FlyAttachment") then HRP.FlyAttachment:Destroy() end
        if HRP:FindFirstChild("FlyLinear") then HRP.FlyLinear:Destroy() end
        if HRP:FindFirstChild("FlyAlign") then HRP.FlyAlign:Destroy() end
        if flyLoop then flyLoop:Disconnect() end; HRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0) 
    end
end
local function ToggleFly() isFlying = not isFlying; UpdateUI(FlyToggle, isFlying); UpdateFly() end
FlyToggle.MouseButton1Click:Connect(ToggleFly); SetupKeybind(FlyKey, "Fly", ToggleFly)

-- Orijinal Speed Kodu
local function UpdateSpeed()
    if isSpeedEnabled then
        speedLoop = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character; if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = NebulaConfig.Sliders.WalkSpeed end
        end)
    else
        if speedLoop then speedLoop:Disconnect() end
        local char = LocalPlayer.Character; if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = 16 end
    end
end
local function ToggleSpeed() isSpeedEnabled = not isSpeedEnabled; UpdateUI(SpeedToggle, isSpeedEnabled); UpdateSpeed() end
SpeedToggle.MouseButton1Click:Connect(ToggleSpeed); SetupKeybind(SpeedKey, "WalkSpeed", ToggleSpeed)

-- KUSURSUZ SPINBOT
local function UpdateSpin()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then return end
    
    local HRP = char.HumanoidRootPart
    local Humanoid = char:FindFirstChildOfClass("Humanoid")
    
    if isSpinning then
        Humanoid.AutoRotate = false
        if HRP:FindFirstChild("NebulaSpin") then HRP.NebulaSpin:Destroy() end
        
        local spinForce = Instance.new("BodyAngularVelocity", HRP)
        spinForce.Name = "NebulaSpin"
        spinForce.MaxTorque = Vector3.new(0, math.huge, 0)
        
        spinLoop = RunService.RenderStepped:Connect(function() 
            if spinForce and spinForce.Parent then 
                spinForce.AngularVelocity = Vector3.new(0, NebulaConfig.Sliders.SpinSpeed / 5, 0) 
            end 
        end)
    else
        Humanoid.AutoRotate = true
        if spinLoop then spinLoop:Disconnect() end
        if HRP:FindFirstChild("NebulaSpin") then HRP.NebulaSpin:Destroy() end
    end
end
local function ToggleSpin() isSpinning = not isSpinning; UpdateUI(SpinToggle, isSpinning); UpdateSpin() end
SpinToggle.MouseButton1Click:Connect(ToggleSpin); SetupKeybind(SpinKey, "Spin", ToggleSpin)

local function UpdateJump()
    if isInfJumpEnabled then
        infJumpConnection = UserInputService.JumpRequest:Connect(function()
            local char = LocalPlayer.Character; if char and char:FindFirstChild("Humanoid") then char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
    else
        if infJumpConnection then infJumpConnection:Disconnect() end
    end
end
local function ToggleJump() isInfJumpEnabled = not isInfJumpEnabled; UpdateUI(JumpToggle, isInfJumpEnabled); UpdateJump() end
JumpToggle.MouseButton1Click:Connect(ToggleJump); SetupKeybind(JumpKey, "Jump", ToggleJump)

local function UpdateNoclip()
    if isNoclipEnabled then
        noclipLoop = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
                end
            end
        end)
    else 
        if noclipLoop then noclipLoop:Disconnect() end 
    end
end
local function ToggleNoclip() isNoclipEnabled = not isNoclipEnabled; UpdateUI(NoclipToggle, isNoclipEnabled); UpdateNoclip() end
NoclipToggle.MouseButton1Click:Connect(ToggleNoclip); SetupKeybind(NoclipKey, "Noclip", ToggleNoclip)

PlayerPanelToggle.MouseButton1Click:Connect(function()
    PlayerPanelFrame.Visible = not PlayerPanelFrame.Visible
    UpdateUI(PlayerPanelToggle, PlayerPanelFrame.Visible)
end)


-- ==========================================
-- // YENİ: LOKASYON / IŞINLANMA SEKME MODÜLLERİ //
-- ==========================================
local SavePosBtn, SavePosLbl = CreateActionModule("📍 Pozisyon Kaydet", "KAYDET", LocScrollFrame)
local LoadPosBtn, LoadPosLbl = CreateActionModule("⚡ Pozisyon TP", "IŞINLAN", LocScrollFrame)
local AutoTPMod, AutoTPToggle, _, AutoTPKey = CreateModule("⏱️ Otomatik TP (0.9 Saniye)", false, LocScrollFrame)

-- 1. Pozisyonu Hafızaya Kaydetme
SavePosBtn.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        savedCFrame = char.HumanoidRootPart.CFrame
        SavePosBtn.Text = "KAYDEDİLDİ!"
        SavePosBtn.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
        task.delay(1, function()
            SavePosBtn.Text = "KAYDET"
            SavePosBtn.BackgroundColor3 = Color3.fromRGB(165, 94, 234)
        end)
    end
end)

-- 2. Kaydedilen Pozisyona Tek Seferlik Dönme
LoadPosBtn.MouseButton1Click:Connect(function()
    if savedCFrame then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = savedCFrame
            char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    else
        LoadPosBtn.Text = "KAYIT YOK!"
        LoadPosBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        task.delay(1, function()
            LoadPosBtn.Text = "IŞINLAN"
            LoadPosBtn.BackgroundColor3 = Color3.fromRGB(165, 94, 234)
        end)
    end
end)

-- 3. Otomatik Hit & Run (0.9 Saniyede Bir Dönüş)
local function UpdateAutoTP()
    if isAutoTPEnabled then
        autoTPLoopConn = RunService.Stepped:Connect(function()
            -- 0.9 saniyede bir TP atar. Bu süre içinde adam serbestçe hareket edebilir.
            if tick() - lastTPTime >= 0.9 then
                lastTPTime = tick()
                if savedCFrame and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = savedCFrame
                    -- İvmeyi sıfırla ki havada kayma olmasın
                    LocalPlayer.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
                end
            end
        end)
    else
        if autoTPLoopConn then autoTPLoopConn:Disconnect(); autoTPLoopConn = nil end
    end
end
local function ToggleAutoTP() 
    if not savedCFrame then
        AutoTPToggle.Text = "KAYIT YOK"
        task.delay(1, function() UpdateUI(AutoTPToggle, isAutoTPEnabled) end)
        return
    end
    isAutoTPEnabled = not isAutoTPEnabled; 
    UpdateUI(AutoTPToggle, isAutoTPEnabled); 
    UpdateAutoTP() 
end
AutoTPToggle.MouseButton1Click:Connect(ToggleAutoTP); SetupKeybind(AutoTPKey, "AutoTP", ToggleAutoTP)


-- // İZLEME (SPECTATE) SİSTEMİ //
local function UpdateSpectate()
    if spectateConn then spectateConn:Disconnect(); spectateConn = nil end
    if spectatedPlayer then
        local function ApplyCamera()
            if spectatedPlayer and spectatedPlayer.Character and spectatedPlayer.Character:FindFirstChild("Humanoid") then
                workspace.CurrentCamera.CameraSubject = spectatedPlayer.Character.Humanoid
            end
        end
        ApplyCamera()
        spectateConn = spectatedPlayer.CharacterAdded:Connect(function(char) task.wait(0.5); ApplyCamera() end)
    else
        local myChar = LocalPlayer.Character
        if myChar and myChar:FindFirstChild("Humanoid") then workspace.CurrentCamera.CameraSubject = myChar.Humanoid end
    end
end

-- // YENİ ARD ARDA TP (LOOP TP) SİSTEMİ (SPINBOT İLE UYUMLU) //
local function UpdateAttach()
    if attachLoop then attachLoop:Disconnect(); attachLoop = nil end
    if attachedPlayer then
        attachLoop = RunService.Heartbeat:Connect(function()
            local lChar = LocalPlayer.Character
            local tChar = attachedPlayer.Character
            if lChar and tChar then
                local lHRP = lChar:FindFirstChild("HumanoidRootPart")
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                if lHRP and tHRP then
                    lHRP.CFrame = CFrame.new(tHRP.Position) * (lHRP.CFrame - lHRP.Position)
                end
            end
        end)
    end
end

-- // AKTİF OYUNCULAR (LİSTE OLUŞTURUCU) //
local function RefreshPlayerList()
    for _, child in ipairs(PlayerScrollFrame:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local PFrame = Instance.new("Frame", PlayerScrollFrame)
        PFrame.Size = UDim2.new(1, -20, 0, 50); PFrame.BackgroundColor3 = Color3.fromRGB(30, 25, 45); PFrame.ZIndex = 12
        Instance.new("UICorner", PFrame).CornerRadius = UDim.new(0, 8)

        local Avatar = Instance.new("ImageLabel", PFrame)
        Avatar.Size = UDim2.new(0, 40, 0, 40); Avatar.Position = UDim2.new(0, 5, 0, 5); Avatar.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Avatar.ZIndex = 13
        Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1, 0)
        coroutine.wrap(function()
            local thumb = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            Avatar.Image = thumb
        end)()

        local NameLbl = Instance.new("TextLabel", PFrame)
        NameLbl.Size = UDim2.new(0, 160, 1, 0); NameLbl.Position = UDim2.new(0, 55, 0, 0); NameLbl.BackgroundTransparency = 1; NameLbl.ZIndex = 13
        NameLbl.Text = player.DisplayName .. "\n(@" .. player.Name .. ")"; NameLbl.TextColor3 = Color3.fromRGB(230, 230, 230); NameLbl.Font = Enum.Font.GothamSemibold; NameLbl.TextSize = 11; NameLbl.TextXAlignment = Enum.TextXAlignment.Left

        local TPBtn = Instance.new("TextButton", PFrame)
        TPBtn.Size = UDim2.new(0, 35, 0, 30); TPBtn.Position = UDim2.new(1, -40, 0, 10); TPBtn.BackgroundColor3 = Color3.fromRGB(165, 94, 234); TPBtn.ZIndex = 14
        TPBtn.Text = "TP"; TPBtn.TextColor3 = Color3.fromRGB(255, 255, 255); TPBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", TPBtn).CornerRadius = UDim.new(0, 6)
        TPBtn.MouseButton1Click:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
            end
        end)

        local AttachBtn = Instance.new("TextButton", PFrame)
        AttachBtn.Size = UDim2.new(0, 35, 0, 30); AttachBtn.Position = UDim2.new(1, -80, 0, 10); AttachBtn.ZIndex = 14
        AttachBtn.BackgroundColor3 = (attachedPlayer == player) and Color3.fromRGB(255, 60, 100) or Color3.fromRGB(60, 50, 80)
        AttachBtn.Text = "🧲"; AttachBtn.TextColor3 = Color3.fromRGB(255, 255, 255); AttachBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", AttachBtn).CornerRadius = UDim.new(0, 6)
        AttachBtn.MouseButton1Click:Connect(function()
            if attachedPlayer == player then attachedPlayer = nil else attachedPlayer = player end
            UpdateAttach()
            RefreshPlayerList()
        end)

        local ESPBtn = Instance.new("TextButton", PFrame)
        ESPBtn.Size = UDim2.new(0, 45, 0, 30); ESPBtn.Position = UDim2.new(1, -130, 0, 10); ESPBtn.ZIndex = 14
        ESPBtn.BackgroundColor3 = activeESPs[player] and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(60, 50, 80)
        ESPBtn.Text = "ESP"; ESPBtn.TextColor3 = Color3.fromRGB(255, 255, 255); ESPBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", ESPBtn).CornerRadius = UDim.new(0, 6)
        ESPBtn.MouseButton1Click:Connect(function()
            activeESPs[player] = not activeESPs[player]
            if activeESPs[player] then ESPBtn.BackgroundColor3 = Color3.fromRGB(80, 255, 80); ApplyESP(player)
            else ESPBtn.BackgroundColor3 = Color3.fromRGB(60, 50, 80); if not isGlobalESPEnabled then RemoveESP(player) end end
        end)

        local SpecBtn = Instance.new("TextButton", PFrame)
        SpecBtn.Size = UDim2.new(0, 35, 0, 30); SpecBtn.Position = UDim2.new(1, -170, 0, 10); SpecBtn.ZIndex = 14
        SpecBtn.BackgroundColor3 = (spectatedPlayer == player) and Color3.fromRGB(255, 165, 0) or Color3.fromRGB(60, 50, 80)
        SpecBtn.Text = "👁️"; SpecBtn.TextColor3 = Color3.fromRGB(255, 255, 255); SpecBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", SpecBtn).CornerRadius = UDim.new(0, 6)
        SpecBtn.MouseButton1Click:Connect(function()
            if spectatedPlayer == player then spectatedPlayer = nil else spectatedPlayer = player end
            UpdateSpectate()
            RefreshPlayerList()
        end)
    end
end

Players.PlayerAdded:Connect(function(player) RefreshPlayerList(); player.CharacterAdded:Connect(function() task.wait(1); if activeESPs[player] or isGlobalESPEnabled then ApplyESP(player) end end) end)
Players.PlayerRemoving:Connect(function(player) 
    activeESPs[player] = nil
    if spectatedPlayer == player then spectatedPlayer = nil; UpdateSpectate() end
    if attachedPlayer == player then attachedPlayer = nil; UpdateAttach() end
    RefreshPlayerList() 
end)
for _, p in ipairs(Players:GetPlayers()) do p.CharacterAdded:Connect(function() task.wait(1); if activeESPs[p] or isGlobalESPEnabled then ApplyESP(p) end end) end
RefreshPlayerList()

-- ==========================================
-- // MM2 ÖZEL SEKME FONKSİYONLARI //
-- ==========================================
local MM2ESPMod, MM2ESPToggle, _, MM2ESPKey = CreateModule("🔪 MM2 Rol ESP (Şerif/Katil)", false, MM2ScrollFrame)
local AutoGrabMod, AutoGrabToggle, _, AutoGrabKey = CreateModule("🔫 Auto Grab Gun (Silah Kap)", false, MM2ScrollFrame)

local function UpdateMM2ESP()
    if isMM2ESPEnabled then
        mm2ESPLoop = RunService.RenderStepped:Connect(function()
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local role = "Masum"
                    local color = Color3.fromRGB(0, 255, 0)

                    local function checkTools(parent)
                        if not parent then return end
                        for _, item in ipairs(parent:GetChildren()) do
                            if item:IsA("Tool") then
                                if item.Name == "Gun" then
                                    role = "Şerif"; color = Color3.fromRGB(0, 0, 255)
                                elseif item.Name ~= "Compass" and item.Name ~= "Radio" and item.Name ~= "Teddy" and item.Name ~= "Gun" then
                                    role = "Katil"; color = Color3.fromRGB(255, 0, 0)
                                end
                            end
                        end
                    end
                    checkTools(player.Backpack); checkTools(player.Character)

                    local hl = player.Character:FindFirstChild("MM2RoleESP")
                    if not hl then
                        hl = Instance.new("Highlight"); hl.Name = "MM2RoleESP"; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = player.Character
                        local bill = Instance.new("BillboardGui", hl); bill.Name = "RoleText"; bill.Size = UDim2.new(0, 100, 0, 30); bill.StudsOffset = Vector3.new(0, 3.5, 0); bill.AlwaysOnTop = true
                        local txt = Instance.new("TextLabel", bill); txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.Font = Enum.Font.GothamBlack; txt.TextSize = 16; txt.TextStrokeTransparency = 0
                    end
                    hl.FillColor = color; hl.OutlineColor = color; hl.FillTransparency = 0.6
                    local textLabel = hl.RoleText:FindFirstChildOfClass("TextLabel")
                    if textLabel then textLabel.Text = role; textLabel.TextColor3 = color end
                end
            end
        end)
    else
        if mm2ESPLoop then mm2ESPLoop:Disconnect() end
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character and player.Character:FindFirstChild("MM2RoleESP") then player.Character.MM2RoleESP:Destroy() end
        end
    end
end
local function ToggleMM2ESP() isMM2ESPEnabled = not isMM2ESPEnabled; UpdateUI(MM2ESPToggle, isMM2ESPEnabled); UpdateMM2ESP() end
MM2ESPToggle.MouseButton1Click:Connect(ToggleMM2ESP); SetupKeybind(MM2ESPKey, "MM2ESP", ToggleMM2ESP)

local function UpdateAutoGrab()
    if isAutoGrabEnabled then
        autoGrabLoop = RunService.Stepped:Connect(function()
            local gunDrop = workspace:FindFirstChild("GunDrop")
            if gunDrop and not grabbingGun and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                grabbingGun = true
                local hrp = LocalPlayer.Character.HumanoidRootPart
                local oldPos = hrp.CFrame
                hrp.CFrame = gunDrop.CFrame
                task.spawn(function()
                    task.wait(0.3)
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then hrp.CFrame = oldPos end
                    task.wait(1)
                    grabbingGun = false
                end)
            end
        end)
    else
        if autoGrabLoop then autoGrabLoop:Disconnect() end
    end
end
local function ToggleAutoGrab() isAutoGrabEnabled = not isAutoGrabEnabled; UpdateUI(AutoGrabToggle, isAutoGrabEnabled); UpdateAutoGrab() end
AutoGrabToggle.MouseButton1Click:Connect(ToggleAutoGrab); SetupKeybind(AutoGrabKey, "AutoGrab", ToggleAutoGrab)


-- // KAPATMA BÖLÜMÜ //
CloseBtn.MouseButton1Click:Connect(function()
    isFlying = false; UpdateFly()
    isSpeedEnabled = false; UpdateSpeed()
    isSpinning = false; UpdateSpin() 
    isNoclipEnabled = false; UpdateNoclip()
    isGlobalESPEnabled = false; UpdateGlobalESP()
    isMM2ESPEnabled = false; UpdateMM2ESP()
    isAutoGrabEnabled = false; UpdateAutoGrab()
    isAutoTPEnabled = false; UpdateAutoTP()
    
    spectatedPlayer = nil; UpdateSpectate()
    attachedPlayer = nil; UpdateAttach()
    
    for _, p in ipairs(Players:GetPlayers()) do RemoveESP(p) end
    for _, conn in ipairs(eventConnections) do if conn then conn:Disconnect() end end
    ScreenGui:Destroy()
end)
